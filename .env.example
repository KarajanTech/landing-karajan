# Copy this file to `.env` and fill in your Supabase project's values for local dev.
# On Vercel/Netlify, add these same two variables in the project's env settings.
#
# Both are PUBLIC values (shipped in the client bundle). The anon key is safe to
# expose — your data is protected by row-level security (see supabase/schema.sql).
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-public-key
