---
/**
 * Monospace section index — e.g. "01 — ORCHESTRATION LAYER".
 * The leading index renders in the accent colour; the label stays faint.
 */
interface Props {
  index?: string;
  label: string;
}
const { index, label } = Astro.props;
---

<span class="eyebrow">
  {index && <span class="eyebrow__index">{index}</span>}
  <span class="eyebrow__sep" aria-hidden="true"></span>
  <span>{label}</span>
</span>
